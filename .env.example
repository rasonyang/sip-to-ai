# Buffer Configuration
UPLINK_BUF_FRAMES=100
DOWNLINK_BUF_FRAMES=200

# AI Vendor Configuration
# Options: openai, deepgram, gemini, grok
AI_VENDOR=openai

# Agent Prompt File (REQUIRED for Deepgram, OpenAI)
# YAML file containing greeting and instructions
AGENT_PROMPT_FILE=agent_prompt.yaml

# OpenAI Configuration (when AI_VENDOR=openai)
OPENAI_API_KEY=your_openai_api_key_here
# Optional. If set, it must match the project that owns OPENAI_API_KEY.
OPENAI_WS_ENDPOINT=wss://api.openai.com/v1/realtime
OPENAI_PROJECT=your_openai_project_id_here
OPENAI_MODEL=gpt-realtime-2

# Deepgram Configuration (when AI_VENDOR=deepgram)
DEEPGRAM_API_KEY=your_deepgram_api_key_here
DEEPGRAM_LISTEN_MODEL=nova-2  # STT model: nova-2, nova-3
DEEPGRAM_SPEAK_MODEL=aura-asteria-en  # TTS voice: aura-asteria-en, aura-luna-en, etc.
DEEPGRAM_LLM_MODEL=gpt-4o-mini  # LLM for agent: gpt-4o-mini, gpt-4o, etc.

# Gemini Live Configuration (when AI_VENDOR=gemini)
# Get API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025  # Gemini 2.5 Flash with native audio
GEMINI_VOICE=Puck  # Voice: Puck, Charon, Kore, Fenrir, Aoede

# xAI Grok Voice Configuration (when AI_VENDOR=grok)
# Get API key from: https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here
GROK_MODEL=grok-voice-think-fast-1.0  # Options: grok-voice-fast-1.0, grok-voice-think-fast-1.0
GROK_VOICE=eve  # Built-in voices: eve (default), ara, leo, rex, sal
GROK_WS_ENDPOINT=wss://api.x.ai/v1/realtime

# SIP Configuration (Userless Account - Receive Only)
# No registration required, only listens for incoming SIP INVITE requests
# Typically used in internal network, TLS not required
SIP_DOMAIN=localhost  # SIP domain or IP address (useful for multi-IP servers)
SIP_TRANSPORT_TYPE=udp
SIP_PORT=6060

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Connection Management
HEALTH_CHECK_INTERVAL_SEC=30
RECONNECT_DELAY_SEC=5
MAX_RECONNECT_ATTEMPTS=3
